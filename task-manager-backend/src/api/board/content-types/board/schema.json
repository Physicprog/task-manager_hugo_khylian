{
  "kind": "collectionType",
  "collectionName": "boards",
  "info": {
    "singularName": "board",
    "pluralName": "boards",
    "displayName": "Board",
    "description": "Task  boards"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "maxLength": 255,
      "required": true
    },
    "description": {
      "type": "text"
    },
    "label": {
      "type": "enumeration",
      "required": true,
      "default": "Red",
      "enum": [
        "Red",
        "Blue",
        "Green",
        "Yellow",
        "Purple",
        "Orange",
        "Pink"
      ]
    },
    "endDate": {
      "type": "date"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "boards"
    }
  }
}
